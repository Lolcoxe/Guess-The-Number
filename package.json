{
  "name": "guess-the-number",
  "version": "1.0.0",
  "description": "A fun number guessing game with login and leaderboard",
  "main": "main.js",
  "homepage": "./",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "author": "Lolcoxe",
  "license": "MIT",
  "devDependencies": {
    "electron": "latest",
    "electron-builder": "latest"
  },
  "build": {
    "appId": "com.guessTheNumber.app",
    "productName": "Guess The Number",
    "files": [
      "main.js",
      "index.html",
      "style.css",
      "script.js"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
